# Unsloth compiled cache (auto-generated on first run)
unsloth_compiled_cache/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python/

# Jupyter notebooks (except the main training one)
*.ipynb
.ipynb_checkpoints/
!training/main-training.ipynb

# Node.js
node_modules/
.bun/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Training environment (contains large binaries)
unsloth_env/

# Training output (model weights ~1GB, hosted on Hugging Face)
training/output/
training/output-v2/
training/output-v3/

# W&B local cache
wandb/
